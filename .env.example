# Copy this file to `.env` and fill it in. `.env` is gitignored.
# Pick ONE provider section.

# --- Provider A: Gemini (laptop / no-GPU) ---------------------------------
# Get a free key at https://aistudio.google.com/apikey
# Default model is gemini/gemini-2.5-flash if MEMTREE_MODEL_ID is unset.
GEMINI_API_KEY=

# --- Provider B: Groq (laptop, generous free tier) ------------------------
# Get a free key at https://console.groq.com/keys
# Recommended (reasoning, code-strong):
#   MEMTREE_MODEL_ID=groq/openai/gpt-oss-120b
# Fallback (non-reasoning, safer for smolagents code-as-action):
#   MEMTREE_MODEL_ID=groq/llama-3.3-70b-versatile
# GROQ_API_KEY=
# MEMTREE_MODEL_ID=groq/openai/gpt-oss-120b

# --- Provider C: Ollama (local GPU/CPU on laptop or HPC node) -------------
# Pull a non-reasoning code-strong model on the same host first:
#   ollama pull qwen2.5-coder:14b-instruct-q4_K_M
# Smaller fallback for tighter VRAM: qwen2.5-coder:7b-instruct
# Then uncomment both lines below. No API key is required.
# MEMTREE_MODEL_ID=ollama_chat/qwen2.5-coder:14b-instruct-q4_K_M
# MEMTREE_API_BASE=http://localhost:11434

# --- Provider D: Grok / xAI (laptop, paid API) ----------------------------
# Get a key at https://console.x.ai/  (requires prepaid credits)
# XAI_API_KEY=
# MEMTREE_MODEL_ID=xai/grok-code-fast-1

# --- Provider E: vLLM on an HPC GPU node ----------------------------------
# Start the server on the GPU node (in another shell or as a Slurm job):
#   vllm serve Qwen/Qwen2.5-Coder-7B-Instruct --port 8000
# MEMTREE_MODEL_ID=hosted_vllm/Qwen/Qwen2.5-Coder-7B-Instruct
# MEMTREE_API_BASE=http://localhost:8000/v1

# --- Provider F: Qwen Cloud / DashScope (paid, OpenAI-compatible) ---------
# Get a key at https://bailian.console.alibabacloud.com/?apiKey=1 (intl)
# DashScope is reached through LiteLLM's openai/ prefix + custom api_base.
# Set OPENAI_API_KEY to your DashScope key (LiteLLM reads it for openai/* ids).
# Code-strong recommended:
#   MEMTREE_MODEL_ID=openai/qwen3-coder-plus
# General-purpose alternatives: qwen3-max, qwen-max, qwen-plus
# OPENAI_API_KEY=
# MEMTREE_MODEL_ID=openai/qwen3-coder-plus
# MEMTREE_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
